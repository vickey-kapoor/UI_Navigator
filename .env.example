# ── Required ─────────────────────────────────────────────────────────────────
# Gemini API key (get one at https://aistudio.google.com/apikey)
GOOGLE_API_KEY=your-gemini-api-key-here

# ── Auth & Security ───────────────────────────────────────────────────────────
# Comma-separated list of valid API keys for the X-API-Key header.
# Leave empty to disable auth (development only).
# API_KEYS=your-key-1,your-key-2
API_KEYS=

# Comma-separated list of allowed CORS origins.
# Default is chrome-extension://* only (restrictive, NOT wildcard).
# Set explicitly in production.
# Example: CORS_ORIGINS=*,https://myapp.com,chrome-extension://abcdef123
CORS_ORIGINS=

# Rate limit in requests per minute per API key (default 60).
RATE_LIMIT_RPM=60

# ── Browser ───────────────────────────────────────────────────────────────────
# Run Chromium in headless mode. Set to "false" to see the browser window.
BROWSER_HEADLESS=true
BROWSER_WIDTH=1280
BROWSER_HEIGHT=800

# ── Agent ─────────────────────────────────────────────────────────────────────
# Maximum number of concurrent browser sessions.
MAX_CONCURRENT_TASKS=5

# ── Persistence ───────────────────────────────────────────────────────────────
# Task store backend: "memory" (default) or "firestore".
TASK_STORE=memory

# ── GCP (deploy only) ────────────────────────────────────────────────────────
# Required for Cloud Run deployment and GCP integrations.
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_REGION=us-central1

# GCS bucket for screenshot uploads (optional).
GCS_BUCKET=

# ── WebPilot ─────────────────────────────────────────────────────────────────
# Gemini model for the legacy (per-call) handler.
# If not set, defaults to gemini-2.5-flash.
GEMINI_MODEL=gemini-2.5-flash

# Gemini model for the Live API (persistent session) handler.
# If not set, defaults to gemini-live-2.5-flash-preview.
GEMINI_LIVE_MODEL=gemini-live-2.5-flash-preview

# Inactive session cleanup threshold in seconds.
# If not set, defaults to 1800 (30 minutes).
MAX_SESSION_DURATION=1800

# Number of consecutive identical screenshots before injecting a "stuck" hint.
# If not set, defaults to 3.
MAX_RETRIES=3

# Hard timeout (seconds) for the entire action loop. Prevents the extension
# from being stuck in RUNNING permanently if the loop hangs.
# If not set, defaults to 120.
ACTION_LOOP_TIMEOUT=120

# Maximum steps per action loop invocation. Recursive calls after interrupts
# inherit half this budget. If not set, defaults to 30.
MAX_LOOP_STEPS=30

# ── Observability ─────────────────────────────────────────────────────────────
# Log level: DEBUG, INFO, WARNING, ERROR (default INFO).
LOG_LEVEL=INFO
